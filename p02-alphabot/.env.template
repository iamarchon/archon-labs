# AlphaBot — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Alpaca Broker API
ALPACA_KEY=your_alpaca_api_key_here
ALPACA_SECRET=your_alpaca_api_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets   # paper endpoint — change to live only when ready

# Anthropic Claude
ANTHROPIC_KEY=your_anthropic_api_key_here

# Trading mode — MUST be explicitly set to false for live trading
PAPER=true

# Starting capital (USD)
STARTING_CAPITAL=100.00
